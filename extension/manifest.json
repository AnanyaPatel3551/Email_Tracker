{
  "manifest_version": 3,
  "name": "Gmail Email Tracker",
  "version": "1.0",
  "description": "Injects tracking pixels into Gmail compose windows.",
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
